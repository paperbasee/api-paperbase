# Copy to .env and adjust values. Never commit real secrets.
#
# Primary settings module (Docker, local, production):
#DJANGO_SETTINGS_MODULE=config.settings.runtime

# -----------------------------------------------------------------------------
# Core (required in production: DEBUG=false)
# -----------------------------------------------------------------------------
#DEBUG=true
#SECRET_KEY=change-me-to-a-long-random-string-at-least-32-characters

# Comma-separated Host headers Django will accept
#ALLOWED_HOSTS=localhost,127.0.0.1

# HTTP port for Gunicorn (container platforms usually inject PORT)
#PORT=8000

# -----------------------------------------------------------------------------
# Database (Postgres only — required; no SQLite)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://paperbase:paperbase@db:5432/paperbase
# Direct Postgres connection for backup/restore scripts (must bypass PgBouncer):
# DIRECT_DATABASE_URL=postgresql://paperbase:paperbase@db:5432/paperbase

# PgBouncer / transaction pooler: set to true when Django must not use server-side cursors
# DATABASE_PGBOUNCER=false

# -----------------------------------------------------------------------------
# Redis (required when DEBUG=false; optional when DEBUG=true)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Production-only (when DEBUG=false)
# -----------------------------------------------------------------------------
# STORE_API_KEY_SECRET=
# CSRF_TRUSTED_ORIGINS=https://your-frontend.example,https://your-api.example
# SECURE_SSL_REDIRECT=true
# USE_X_FORWARDED_PROTO=false

# -----------------------------------------------------------------------------
# Media storage (S3-compatible API, e.g. Cloudflare R2 — required for config.settings.runtime)
# -----------------------------------------------------------------------------
# Provider values go into standard boto3 / django-storages names (same in Docker and production).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=storage-paperbase
# AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# Public object hostname or full URL (https://storage.example.com is accepted)
# AWS_S3_CUSTOM_DOMAIN=storage.paperbase.me
#
# Optional (default in settings: auto)
# AWS_S3_REGION_NAME=auto

# -----------------------------------------------------------------------------
# PostgreSQL backups to R2 (optional Docker service: docker compose --profile backup)
# Reuses AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_S3_ENDPOINT_URL, DIRECT_DATABASE_URL.
# Cron in the backup container uses UTC unless you set TZ on the service.
# -----------------------------------------------------------------------------
#BACKUP_S3_BUCKET=
# Defaults to AWS_STORAGE_BUCKET_NAME when BACKUP_S3_BUCKET is unset.
#BACKUP_PREFIX_FULL=backups/full
#BACKUP_PREFIX_SNAPSHOT=backups/snapshot
# Backward compatibility: if BACKUP_PREFIX_SNAPSHOT is unset, scripts fall back to BACKUP_PREFIX_WAL.
#BACKUP_PREFIX_WAL=
# Latest backup pointer object in bucket:
#BACKUP_META_LATEST_KEY=meta/latest.json
# Daily full backup (pg_dump | gzip -> .sql.gz), default 02:00 UTC:
#BACKUP_CRON_FULL=0 2 * * *
# Frequent logical snapshots (pg_dump -Fc -> .dump), default every 10 minutes UTC:
#BACKUP_CRON_SNAPSHOT=*/10 * * * *
# Optional container timezone for cron interpretation (default UTC when unset):
#TZ=UTC
#BACKUP_TMP_DIR=/tmp/paperbase-backup
#BACKUP_AWS_MAX_ATTEMPTS=3
#BACKUP_PG_WAIT_SECONDS=120
# Optional extra pg_dump flags (space-separated, quoted in .env if needed):
#PG_DUMP_EXTRA_ARGS=
# AWS CLI signing region; R2 often uses "auto" (if your aws CLI errors, try us-east-1):
#AWS_DEFAULT_REGION=auto

# Restore helper (scripts/restore.sh): pass target DB URL as first positional argument.
# Optional pg_restore: set to 1 to add --clean --if-exists (destructive)
#RESTORE_PGRESTORE_CLEAN=0
#PG_RESTORE_EXTRA_ARGS=

# -----------------------------------------------------------------------------
# Optional app features (see codebase for behavior when unset)
# -----------------------------------------------------------------------------
# ADMIN_PATH=admin/
# FRONTEND_URL=http://localhost:3000
# FIELD_ENCRYPTION_KEY=
# RESEND_API_KEY=
# TURNSTILE_SECRET_KEY=
# SENTRY_DSN=https://<key>@o<org-id>.ingest.us.sentry.io/<project-id>
# PLATFORM_HOSTS=
# PLATFORM_ROOT_DOMAIN=

# -----------------------------------------------------------------------------
# Meta / Facebook tracking (CAPI)
# -----------------------------------------------------------------------------
# Graph API version used for Conversion API calls (default: v25.0)
# META_GRAPH_API_VERSION=v25.0
#
# How long to retain StoreEventLog rows for the "tracking" app (default: 72h)
# EVENT_LOG_RETENTION_HOURS=72
